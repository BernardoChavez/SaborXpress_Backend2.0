APP_NAME=SaborXpress
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Producción (Render): APP_URL=https://tu-servicio.onrender.com  (sin barra final)

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_MX

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Base de datos local (SQLite) ---
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# --- Supabase / PostgreSQL (producción) ---
# En Supabase: Project Settings → Database → Connection string (URI o parámetros).
# Suele ser host: db.xxxxx.supabase.co, puerto 5432 (sesión) o 6543 (pooler transaction).
# DB_CONNECTION=pgsql
# DB_HOST=db.xxxxx.supabase.co
# DB_PORT=5432
# DB_DATABASE=postgres
# DB_USERNAME=postgres
# DB_PASSWORD=tu_password
# Supabase suele requerir SSL:
# DB_SSLMODE=require

SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

# CORS: orígenes del frontend (coma separada). En producción incluye la URL de tu front en Render.
# Ejemplo: https://saborxpress-front.onrender.com,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173
CORS_SUPPORTS_CREDENTIALS=false

# Sanctum (SPA con cookies; si solo usas Bearer en el front, es opcional)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

MAIL_MAILER=log
